<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ManageAppointments"
             x:Class="ManageAppointments.MainPageDesktop"
             xmlns:behaviors="clr-namespace:ManageAppointments.Behaviors"
             xmlns:listView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView">

    <ContentPage.Behaviors>
        <behaviors:DesktopMainPageBehavior/>
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
        <!-- App Bar -->
        <Grid BackgroundColor="{AppThemeBinding Light={StaticResource AppointmentManagerPrimaryBackground}, Dark={StaticResource AppointmentManagerPrimaryBackgroundDark}}"  HeightRequest="48" Grid.Row="0">
            <Label Text="Doctorspot"
                   TextColor="{AppThemeBinding Light={StaticResource AppointmentManagerPrimaryForeground}, Dark={StaticResource AppointmentManagerPrimaryForegroundDark}}"
                   FontSize="20"
                   VerticalOptions="Center"
                   Margin="24,10,0,10"/>
        </Grid>

        <!-- Main Layout Below App Bar -->
        <Grid Grid.Row="1"
              x:Name="dashBoardGrid"
              ColumnDefinitions="200,*"
              BackgroundColor="{AppThemeBinding Light={StaticResource AppointmentManagerContentBackground}, Dark={StaticResource AppointmentManagerContentBackgroundDark}}">

            <Grid Grid.Column="0" Margin="0,10,0,0" Background="{AppThemeBinding Light={StaticResource AppointmentManagerContentBackground}, Dark={StaticResource AppointmentManagerContentBackgroundDark}}">
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource AppointmentManagerBorder}, Dark={StaticResource AppointmentManagerBorderDark}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0,20,0,0" />
                    </Border.StrokeShape>

                    <!-- Sidebar Menu -->
                    <listView:SfListView x:Name="listViewWindows" 
                SelectionMode="Single"
                BackgroundColor="{AppThemeBinding Light={StaticResource AppointmentManagerContentBackground}, Dark={StaticResource AppointmentManagerContentBackgroundDark}}"
                         ItemSize="40">
                        <listView:SfListView.ItemTemplate>
                            <DataTemplate>
                                <ViewCell>
                                    <StackLayout Orientation="Horizontal" Padding="10">
                                        <Label Text="{Binding Glyph}" FontFamily="MauiSampleFontIcon" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource AppointmentManagerContentForeground}, Dark={StaticResource AppointmentManagerContentForegroundDark}}" VerticalOptions="Center" Margin="10,0,0,0"/>
                                        <Label Text="{Binding Title}" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource AppointmentManagerContentForeground}, Dark={StaticResource AppointmentManagerContentForegroundDark}}" VerticalOptions="Center" Margin="10,0,0,0"/>
                                    </StackLayout>
                                </ViewCell>
                            </DataTemplate>
                        </listView:SfListView.ItemTemplate>
                    </listView:SfListView>
                </Border>
            </Grid>

            <ContentView x:Name="mainContentView"
                         Grid.Column="1"
                         Margin="{OnPlatform MacCatalyst='10,10,0,0', WinUI='0,10,0,0'}">
                <local:DashBoard />
            </ContentView>
        </Grid>
    </Grid>

</ContentPage>
